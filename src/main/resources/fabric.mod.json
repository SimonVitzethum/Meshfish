{
	"schemaVersion": 1,
	"id": "meshfish",
	"version": "${version}",
	"name": "Meshfish",
	"description": "A next-generation Vulkan renderer for Minecraft. Meshfish implements a modern graphics pipeline featuring mesh shading and optimized memory management to deliver unparalleled frame rates and stability.",
	"authors": [
		"Simon Vitzethum",
		"Johannes Preiser (aka. JoCraft2010)"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/SimonVitzethum/Meshfish",
		"issues": "https://github.com/SimonVitzethum/Meshfish/issues",
		"simon_github": "https://github.com/SimonVitzethum",
		"jocraft_github": "https://github.com/JoCraft2010"
	},
	"license": "TASL v1.0",
	"icon": "assets/meshfish/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"name.modid.Meshfish"
		],
		"client": [
			"name.modid.client.MeshfishClient"
		]
	},
	"mixins": [
		"meshfish.mixins.json",
		{
			"config": "meshfish.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.6",
		"minecraft": "~26.2-",
		"java": ">=25",
		"fabric-api": "*"
	}
}